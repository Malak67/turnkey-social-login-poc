# --- Turnkey (signer layer) ---------------------------------------------
# Get these from https://app.turnkey.com after creating a parent org.
# Auth Proxy must be enabled in the dashboard so the SDK can create
# end-user sub-orgs from the browser without your backend holding the
# parent API key. See https://docs.turnkey.com → "Auth Proxy".
VITE_TURNKEY_ORGANIZATION_ID=
VITE_TURNKEY_AUTH_PROXY_CONFIG_ID=
# Google OAuth client id — registered in the Turnkey dashboard under
# Authentication → OAuth → Google. The `nonce` binding is handled by
# the SDK; you only need to paste the client id here.
VITE_TURNKEY_GOOGLE_CLIENT_ID=

# X (Twitter) OAuth 2.0 client id — registered as a credential in the
# Turnkey dashboard's OAuth 2.0 tab. Unlike Google (OIDC), X uses
# OAuth 2.0 + PKCE with a confidential client, so the secret lives in
# Turnkey's credential store, not here.
VITE_TURNKEY_X_CLIENT_ID=

# --- WalletConnect (optional) -------------------------------------------
# Only used by the inbound EOA connector in src/wagmi.ts so users can
# bring their own external wallet alongside the Turnkey signer.
# https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=
